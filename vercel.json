{
  "buildCommand": "echo 'Static HTML site, skipping build'",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/contact",
      "destination": "/api/contact.js"
    },
    {
      "source": "/cricket.html",
      "destination": "/cricket.html"
    },
    {
      "source": "/cricket",
      "destination": "/cricket.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

